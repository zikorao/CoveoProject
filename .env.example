# Copy this file to `.env.local` and fill in your Coveo credentials.
# The NEXT_PUBLIC_ prefix exposes these to the browser, which is required for the
# client-side Coveo engine to hydrate. Use a search-scoped (low-privilege) token.
NEXT_PUBLIC_COVEO_ORG_ID=your_organization_id
NEXT_PUBLIC_COVEO_ACCESS_TOKEN=your_search_access_token
